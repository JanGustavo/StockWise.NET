@page "/clientes"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using StockWise.Domain.Entities
@using StockWise.Blazor.Services
@using StockWise.Domain.Extensions
@inject ClienteApiService ApiService
@inject IJSRuntime JSRuntime

<PageTitle>StockWise - Clientes</PageTitle>

<div class="container mt-4">
    @* Cabeçalho e Busca *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>👥 Clientes do Seu Zé</h1>
        <div class="d-flex gap-2">
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="Buscar cliente..."
                       @bind="termoBusca" @bind:event="oninput" />
            </div>
            <button class="btn btn-primary" @onclick="AbrirModal">
                <i class="bi bi-person-plus-fill"></i> Novo Cliente
            </button>
        </div>
    </div>

    @* Estado de Carregamento *@
    @if (clientes == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p class="mt-2">Conectando à API...</p>
        </div>
    }
    @* Lista Vazia *@
    else if (!ClientesFiltrados.Any())
    {
        <div class="alert alert-info shadow-sm border-0">
            <i class="bi bi-info-circle me-2"></i>
            @(string.IsNullOrWhiteSpace(termoBusca) ? "Nenhum cliente cadastrado." : $"Nenhum cliente encontrado para '{termoBusca}'.")
        </div>
    }
    @* Tabela de Dados *@
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Telefone</th>
                        <th class="text-center">Qtd. Pedidos</th>
                        <th class="text-end px-4">Ações</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @foreach (var c in ClientesFiltrados)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@c.Nome</td>
                            <td>@c.Email</td>
                            <td>@c.NumeroTelefone</td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill">@c.QuantidadePedidos</span>
                            </td>
                            <td class="text-end px-4">
                                <button class="btn btn-outline-warning btn-sm border-0 me-2"
                                        @onclick="() => AbrirModalEdicao(c)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm border-0"
                                        @onclick="() => DeletarAsync(c.Id, c.Nome)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Modal de Cadastro *@
@if (exibirModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(novoCliente.Id == 0 ? "👤 Novo Cliente" : "✏️ Editar Cliente")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModal"></button>
                </div>
                <EditForm Model="@novoCliente" OnValidSubmit="SalvarAsync">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nome Completo</label>
                            <InputText @bind-Value="novoCliente.Nome" class="form-control" placeholder="Ex: João Silva"
                                       required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <InputText @bind-Value="novoCliente.Email" type="email" class="form-control"
                                       placeholder="joao@email.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Telefone</label>
                            <InputText @bind-Value="novoCliente.NumeroTelefone" class="form-control"
                                       placeholder="(11) 99999-9999" required />
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" @onclick="FecharModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary px-4">@(novoCliente.Id == 0 ? "Cadastrar" : "Salvar Alterações")</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Cliente>? clientes;
    private Cliente novoCliente = new();
    private string termoBusca = "";
    private bool exibirModal = false;

    // Filtro reativo usando a extensão genérica
    private IEnumerable<Cliente> ClientesFiltrados =>
        clientes.FiltrarPorTexto(termoBusca, c => c.Nome);

    protected override async Task OnInitializedAsync() => await ListarAsync();

    // --- Métodos CRUD ---

    private async Task ListarAsync()
    {
        clientes = await CrudExtensions.CarregarDadosSafeAsync(() => ApiService.GetAllAsync(), "Clientes");
    }

    private async Task SalvarAsync()
    {
        bool sucesso;

        if (novoCliente.Id == 0)
        {
            sucesso = await CrudExtensions.SalvarSafeAsync(
                () => ApiService.CreateAsync(novoCliente),
                "Clientes"
            );
        }
        else
        {
            sucesso = await CrudExtensions.AtualizarSafeAsync(
                () => ApiService.UpdateAsync(novoCliente),
                "Clientes"
            );
        }

        if (sucesso)
        {
            FecharModal();
            await ListarAsync();
        }
    }

    private async Task DeletarAsync(int id, string nome)
    {
        var confirmou = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Deseja realmente remover o cliente '{nome}'?"
        );

        if (!confirmou)
            return;

        var sucesso = await CrudExtensions.DeletarSafeAsync(
            () => ApiService.DeleteAsync(id),
            "Cliente"
        );

        if (sucesso)
            await ListarAsync();
    }

    // --- Controle de UI ---

    private void AbrirModal()
    {
        novoCliente = new Cliente
        {
            Id = 0,
            Nome = "",
            Email = "",
            NumeroTelefone = ""
        };
        exibirModal = true;
    }

    private void AbrirModalEdicao(Cliente cliente)
    {
        novoCliente = new Cliente
        {
            Id = cliente.Id,
            Nome = cliente.Nome,
            Email = cliente.Email,
            NumeroTelefone = cliente.NumeroTelefone,
            QuantidadePedidos = cliente.QuantidadePedidos
        };
        exibirModal = true;
    }

    private void FecharModal() => exibirModal = false;
}
