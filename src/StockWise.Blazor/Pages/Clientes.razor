@page "/clientes"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using StockWise.Domain.Entities
@using StockWise.Blazor.Services
@using StockWise.Domain.Extensions
@inject ClienteApiService ApiService
@inject IJSRuntime JSRuntime

<PageTitle>StockWise - Clientes</PageTitle>

<div class="header-container">
    <div class="main-container">
        <div class="header-content">
            <h1 class="header-title">
                <span>👥</span>
                Clientes
            </h1>
            <div class="header-actions">
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Buscar cliente..." @bind="termoBusca" @bind:event="oninput" />
                    </div>
                </div>
                <button class="btn-primary-custom" @onclick="AbrirModal">
                    <i class="bi bi-person-plus-fill"></i>
                    Novo Cliente
                </button>
            </div>
        </div>
    </div>
</div>

<div class="main-container">
    @if (clientes == null)
    {
        <div class="loading-container">
            <div class="spinner-custom"></div>
            <p class="mt-3 text-secondary fw-bold">Conectando à API...</p>
        </div>
    }
    else if (!ClientesFiltrados.Any())
    {
        <div class="empty-state">
            <div style="font-size: 4rem; margin-bottom: 1rem;">🔍</div>
            <p class="text-secondary fw-bold">
                @(string.IsNullOrWhiteSpace(termoBusca) ? "Nenhum cliente cadastrado." : $"Nenhum cliente encontrado para '{termoBusca}'.")
            </p>
        </div>
    }
    else
    {
        <div class="cards-grid">
            @foreach (var c in ClientesFiltrados)
            {
                <div class="client-card">
                    <div class="client-card-header">
                        <div class="client-avatar">
                            @c.Nome.Substring(0, 1).ToUpper()
                        </div>
                        <div class="client-info-header">
                            <h5 class="client-name">@c.Nome</h5>
                            <span class="client-id">#@c.Id</span>
                        </div>
                    </div>
                    <div class="client-card-body">
                        <div class="contact-item">
                            <i class="bi bi-envelope-fill"></i>
                            <span>@c.Email</span>
                        </div>
                        <div class="contact-item">
                            <i class="bi bi-telephone-fill"></i>
                            <span>@c.NumeroTelefone</span>
                        </div>
                        <div class="orders-section">
                            <span class="text-secondary small fw-bold">ATIVIDADE</span>
                            <div class="orders-badge">
                                <i class="bi bi-cart-check-fill"></i>
                                @c.QuantidadePedidos Pedidos
                            </div>
                        </div>
                    </div>
                    <div class="client-card-footer">
                        <button class="btn-action btn-edit" @onclick="() => AbrirModalEdicao(c)">
                            <i class="bi bi-pencil"></i> Editar
                        </button>
                        <button class="btn-action btn-delete" @onclick="() => DeletarAsync(c.Id, c.Nome)">
                            <i class="bi bi-trash"></i> Remover
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Modal de Cadastro *@
@if (exibirModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi @(novoCliente.Id == 0 ? "bi-person-plus-fill" : "bi-pencil-square")"></i>
                    @(novoCliente.Id == 0 ? "Novo Cliente" : "Editar Cliente")
                </h5>
                <button type="button" class="modal-close-btn" @onclick="FecharModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <EditForm Model="@novoCliente" OnValidSubmit="SalvarAsync">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Nome Completo</label>
                        <InputText @bind-Value="novoCliente.Nome" class="form-input" placeholder="Ex: João Silva" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="novoCliente.Email" type="email" class="form-input" placeholder="joao@email.com" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Telefone</label>
                        <InputText @bind-Value="novoCliente.NumeroTelefone" class="form-input" placeholder="(11) 99999-9999" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-modal btn-cancel" @onclick="FecharModal">Cancelar</button>
                    <button type="submit" class="btn-modal btn-submit">
                        @(novoCliente.Id == 0 ? "Cadastrar Cliente" : "Salvar Alterações")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Cliente>? clientes;
    private Cliente novoCliente = new();
    private string termoBusca = "";
    private bool exibirModal = false;

    private IEnumerable<Cliente> ClientesFiltrados =>
        clientes.FiltrarPorTexto(termoBusca, c => c.Nome);

    protected override async Task OnInitializedAsync() => await ListarAsync();

    private async Task ListarAsync()
    {
        clientes = await CrudExtensions.CarregarDadosSafeAsync(() => ApiService.GetAllAsync(), "Clientes");
    }

    private async Task SalvarAsync()
    {
        bool sucesso;
        if (novoCliente.Id == 0)
        {
            sucesso = await CrudExtensions.SalvarSafeAsync(() => ApiService.CreateAsync(novoCliente), "Clientes");
        }
        else
        {
            sucesso = await CrudExtensions.AtualizarSafeAsync(() => ApiService.UpdateAsync(novoCliente), "Clientes");
        }

        if (sucesso)
        {
            FecharModal();
            await ListarAsync();
        }
    }

    private async Task DeletarAsync(int id, string nome)
    {
        var confirmou = await JSRuntime.InvokeAsync<bool>("confirm", $"Deseja realmente remover o cliente '{nome}'?");
        if (!confirmou) return;
        var sucesso = await CrudExtensions.DeletarSafeAsync(() => ApiService.DeleteAsync(id), "Cliente");
        if (sucesso) await ListarAsync();
    }

    private void AbrirModal()
    {
        novoCliente = new Cliente { Id = 0, Nome = "", Email = "", NumeroTelefone = "" };
        exibirModal = true;
    }

    private void AbrirModalEdicao(Cliente cliente)
    {
        novoCliente = new Cliente
        {
            Id = cliente.Id,
            Nome = cliente.Nome,
            Email = cliente.Email,
            NumeroTelefone = cliente.NumeroTelefone,
            QuantidadePedidos = cliente.QuantidadePedidos
        };
        exibirModal = true;
    }

    private void FecharModal() => exibirModal = false;
}
