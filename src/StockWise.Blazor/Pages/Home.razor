@page "/"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using StockWise.Domain.Entities
@using StockWise.Blazor.Services
@using StockWise.Domain.Extensions
@inject FrutaApiService ApiService
@inject IJSRuntime JSRuntime

<PageTitle>StockWise - Gestão de Frutas</PageTitle>

<style>
    /* ==================== VARIÁVEIS E RESET ==================== */
    :root {
        --primary-color: #10b981;
        --primary-dark: #059669;
        --primary-light: #6ee7b7;
        --secondary-color: #f59e0b;
        --danger-color: #ef4444;
        --dark-bg: #0f172a;
        --card-bg: #ffffff;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --border-color: #e2e8f0;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --shadow-lg: 0 10px 25px -5px rgba(0, 0, 0, 0.15);
        --shadow-xl: 0 20px 40px -10px rgba(0, 0, 0, 0.2);
        --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
        color: var(--text-primary);
        min-height: 100vh;
    }

    /* ==================== HEADER ==================== */
    .header-container {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        padding: 2rem 0;
        box-shadow: var(--shadow-lg);
        position: relative;
        overflow: hidden;
    }

    .header-container::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 500px;
        height: 500px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        animation: float 6s ease-in-out infinite;
    }

    .header-container::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -5%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        animation: float 8s ease-in-out infinite reverse;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-20px);
        }
    }

    .header-content {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .header-title {
        color: white;
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        animation: slideInLeft 0.6s ease-out;
    }

    .header-title span {
        display: inline-block;
        animation: bounce 2s ease-in-out infinite;
    }

    @@keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-10px);
        }
    }

    .header-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
        animation: slideInRight 0.6s ease-out;
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* ==================== SEARCH BAR ==================== */
    .search-container {
        position: relative;
        flex: 1;
        max-width: 350px;
    }

    .search-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 50px;
        padding: 0.5rem 1.5rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        transition: all var(--transition-base);
    }

    .search-input-wrapper:focus-within {
        box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
        transform: translateY(-2px);
    }

    .search-input-wrapper i {
        color: var(--primary-color);
        margin-right: 0.75rem;
        font-size: 1.1rem;
    }

    .search-input-wrapper input {
        border: none;
        background: transparent;
        outline: none;
        flex: 1;
        font-size: 0.95rem;
        color: var(--text-primary);
        font-weight: 500;
    }

    .search-input-wrapper input::placeholder {
        color: var(--text-secondary);
    }

    /* ==================== BUTTONS ==================== */
    .btn-primary-custom {
        background: linear-gradient(135deg, var(--secondary-color) 0%, #f97316 100%);
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all var(--transition-base);
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
        position: relative;
        overflow: hidden;
    }

    .btn-primary-custom::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        background: rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn-primary-custom:hover::before {
        width: 300px;
        height: 300px;
    }

    .btn-primary-custom:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(245, 158, 11, 0.4);
    }

    .btn-primary-custom:active {
        transform: translateY(-1px);
    }

    /* ==================== CONTAINER ==================== */
    .main-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
    }

    /* ==================== EMPTY STATE ==================== */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: var(--shadow-md);
        animation: fadeIn 0.5s ease-out;
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        display: inline-block;
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }
        50% {
            transform: scale(1.1);
            opacity: 0.8;
        }
    }

    .empty-state-text {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 0.5rem;
    }

    /* ==================== LOADING STATE ==================== */
    .loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        gap: 1.5rem;
    }

    .spinner-custom {
        width: 50px;
        height: 50px;
        border: 4px solid var(--border-color);
        border-top-color: var(--primary-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .loading-text {
        font-size: 1rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    /* ==================== CARDS GRID ==================== */
    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ==================== FRUIT CARD ==================== */
    .fruit-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow-md);
        transition: all var(--transition-base);
        cursor: pointer;
        position: relative;
        border: 2px solid transparent;
        animation: cardEnter 0.5s ease-out backwards;
    }

    .fruit-card:nth-child(1) {
        animation-delay: 0.05s;
    }

    .fruit-card:nth-child(2) {
        animation-delay: 0.1s;
    }

    .fruit-card:nth-child(3) {
        animation-delay: 0.15s;
    }

    .fruit-card:nth-child(n+4) {
        animation-delay: 0.2s;
    }

    @@keyframes cardEnter {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fruit-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
    }

    .fruit-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-xl);
        border-color: var(--primary-light);
    }

    .fruit-card-header {
        padding: 1.5rem;
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(110, 231, 183, 0.05) 100%);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
    }

    .fruit-card-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--primary-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
        flex: 1;
    }

    .fruit-card-id {
        background: var(--primary-color);
        color: white;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .fruit-card-body {
        padding: 1.5rem;
    }

    .quantity-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border-color);
    }

    .quantity-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        animation: badgePulse 2s ease-in-out infinite;
    }

    .quantity-badge.low {
        background: linear-gradient(135deg, var(--danger-color) 0%, #f87171 100%);
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    }

    @@keyframes badgePulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    .quantity-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .price-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .price-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
    }

    .price-value {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary-color);
    }

    .fruit-card-footer {
        display: flex;
        gap: 0.75rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
    }

    /* ==================== ACTION BUTTONS ==================== */
    .btn-action {
        flex: 1;
        padding: 0.65rem 1rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all var(--transition-base);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        position: relative;
        overflow: hidden;
    }

    .btn-edit {
        background: linear-gradient(135deg, var(--secondary-color) 0%, #fbbf24 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
    }

    .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(245, 158, 11, 0.3);
    }

    .btn-delete {
        background: linear-gradient(135deg, var(--danger-color) 0%, #f87171 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }

    .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(239, 68, 68, 0.3);
    }

    .btn-action:active {
        transform: translateY(0);
    }

    /* ==================== MODAL ==================== */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.3s ease-out;
        backdrop-filter: blur(4px);
    }

    .modal-content {
        background: white;
        border-radius: 20px;
        box-shadow: var(--shadow-xl);
        max-width: 500px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        animation: modalSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes modalSlideIn {
        from {
            opacity: 0;
            transform: scale(0.9) translateY(-50px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .modal-header {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        color: white;
        padding: 2rem;
        border-bottom: none;
        border-radius: 20px 20px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .modal-close-btn {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        color: white;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all var(--transition-base);
    }

    .modal-close-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: rotate(90deg);
    }

    .modal-body {
        padding: 2rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group:last-child {
        margin-bottom: 0;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-input {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 2px solid var(--border-color);
        border-radius: 10px;
        font-size: 0.95rem;
        transition: all var(--transition-base);
        font-family: inherit;
        color: var(--text-primary);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }

    .form-input:disabled {
        background: var(--border-color);
        color: var(--text-secondary);
        cursor: not-allowed;
    }

    .form-help-text {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-top: 0.35rem;
        font-weight: 500;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .modal-footer {
        padding: 1.5rem 2rem;
        background: var(--border-color);
        border-radius: 0 0 20px 20px;
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
    }

    .btn-modal {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all var(--transition-base);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .btn-cancel {
        background: var(--border-color);
        color: var(--text-primary);
    }

    .btn-cancel:hover {
        background: #cbd5e1;
    }

    .btn-submit {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        min-width: 150px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 25px rgba(16, 185, 129, 0.4);
    }

    .btn-submit:active {
        transform: translateY(0);
    }

    /* ==================== RESPONSIVE ==================== */
    @@media (max-width: 768px) {
        .header-content {
            flex-direction: column;
            align-items: stretch;
        }

        .header-title {
            font-size: 1.8rem;
        }

        .header-actions {
            flex-direction: column;
        }

        .search-container {
            max-width: 100%;
        }

        .cards-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .modal-content {
            width: 95%;
        }
    }

    @@media (max-width: 480px) {
        .main-container {
            padding: 1.5rem 1rem;
        }

        .header-title {
            font-size: 1.5rem;
        }

        .fruit-card-title {
            font-size: 1.1rem;
        }

        .modal-footer {
            flex-direction: column;
        }

        .btn-modal {
            width: 100%;
        }
    }
</style>

<div class="header-container">
    <div class="main-container">
        <div class="header-content">
            <h1 class="header-title">
                <span>🍉</span>
                StockWise
            </h1>
            <div class="header-actions">
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Buscar fruta..." @bind="termoBusca" @bind:event="oninput" />
                    </div>
                </div>
                <button class="btn-primary-custom" @onclick="AbrirModal">
                    <i class="bi bi-plus-circle"></i>
                    Nova Fruta
                </button>
            </div>
        </div>
    </div>
</div>

<div class="main-container">
    @if (frutas == null)
    {
        <div class="loading-container">
            <div class="spinner-custom"></div>
            <p class="loading-text">Conectando à API...</p>
        </div>
    }
    else if (!FrutasFiltradas.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📦</div>
            <p class="empty-state-text">
                @(string.IsNullOrWhiteSpace(termoBusca) 
                    ? "Nenhuma fruta cadastrada no estoque." 
                    : $"Nenhuma fruta encontrada para '{termoBusca}'.")
            </p>
        </div>
    }
    else
    {
        <div class="cards-grid">
            @foreach (var fruta in FrutasFiltradas)
            {
                <div class="fruit-card">
                    <div class="fruit-card-header">
                        <h5 class="fruit-card-title">
                            @(fruta.Nome?.ObterEmojiFruta() ?? "🍎")
                            @fruta.Nome
                        </h5>
                        <span class="fruit-card-id">ID: @fruta.Id</span>
                    </div>
                    <div class="fruit-card-body">
                        <div class="quantity-section">
                            <span class="quantity-badge @(fruta.Quantidade < 5 ? "low" : "")">
                                <i class="bi @(fruta.Quantidade < 5 ? "bi-exclamation-circle" : "bi-check-circle")"></i>
                                @fruta.Quantidade kg
                            </span>
                            <span class="quantity-label">Disponível</span>
                        </div>
                        <div class="price-section">
                            <span class="price-label">Preço</span>
                            <span class="price-value">R$ @fruta.Preco.ToString("F2")</span>
                        </div>
                    </div>
                    <div class="fruit-card-footer">
                        <button class="btn-action btn-edit" @onclick="() => AbrirModalEdicao(fruta)">
                            <i class="bi bi-pencil"></i>
                            Editar
                        </button>
                        <button class="btn-action btn-delete" @onclick="() => DeletarFruta(fruta.Nome!)">
                            <i class="bi bi-trash"></i>
                            Remover
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Modal de Cadastro/Edição *@
@if (exibirModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    @(novaFruta.Id == 0 ? "📦 Cadastrar Nova Fruta" : "✏️ Editar Fruta")
                </h5>
                <button type="button" class="modal-close-btn" @onclick="FecharModal">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <EditForm Model="@novaFruta" OnValidSubmit="SalvarFruta">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Nome da Fruta</label>
                        <InputText @bind-Value="novaFruta.Nome" 
                                   class="form-input" 
                                   placeholder="Ex: Morango" 
                                   disabled="@(novaFruta.Id != 0)" 
                                   required />
                        @if (novaFruta.Id != 0)
                        {
                            <div class="form-help-text">
                                <i class="bi bi-info-circle"></i>
                                O nome da fruta não pode ser alterado após o cadastro.
                            </div>
                        }
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Preço (R$)</label>
                            <InputNumber @bind-Value="novaFruta.Preco" 
                                         class="form-input" 
                                         step="0.01" 
                                         required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Quantidade (kg)</label>
                            <InputNumber @bind-Value="novaFruta.Quantidade" 
                                         class="form-input" 
                                         required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-modal btn-cancel" @onclick="FecharModal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn-modal btn-submit">
                        @(novaFruta.Id == 0 ? "Salvar Fruta" : "Salvar Alterações")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Fruta>? frutas;
    private Fruta novaFruta = new();
    private string termoBusca = "";
    private bool exibirModal = false;

    private IEnumerable<Fruta> FrutasFiltradas =>
        frutas.FiltrarPorTexto(termoBusca, f => f.Nome);

    protected override async Task OnInitializedAsync() => await ListarAsync();

    // --- Métodos CRUD ---

    private async Task ListarAsync()
    {
        frutas = await CrudExtensions.CarregarDadosSafeAsync(
            () => ApiService.GetFrutasAsync(), "Frutas");
    }

    private async Task SalvarFruta()
    {
        bool sucesso;

        if (novaFruta.Id == 0)
        {
            sucesso = await CrudExtensions.SalvarSafeAsync(
                () => ApiService.CadastrarAsync(novaFruta),
                "Fruta"
            );
        }
        else
        {
            sucesso = await CrudExtensions.AtualizarSafeAsync(
                () => ApiService.AtualizarAsync(novaFruta),
                "Fruta"
            );
        }

        if (sucesso)
        {
            await ListarAsync();
            FecharModal();
        }
    }

    private async Task DeletarFruta(string nome)
    {
        var confirmou = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Deseja realmente remover a fruta '{nome}'?"
        );

        if (!confirmou)
            return;

        var sucesso = await CrudExtensions.DeletarSafeAsync(
            () => ApiService.RemoverAsync(nome),
            "Fruta"
        );

        if (sucesso)
            await ListarAsync();
    }

    private void AbrirModal()
    {
        novaFruta = new Fruta
        {
            Id = 0,
            Nome = "",
            Preco = 0,
            Quantidade = 0
        };
        exibirModal = true;
    }

    private void AbrirModalEdicao(Fruta fruta)
    {
        novaFruta = new Fruta
        {
            Id = fruta.Id,
            Nome = fruta.Nome,
            Preco = fruta.Preco,
            Quantidade = fruta.Quantidade
        };
        exibirModal = true;
    }

    private void FecharModal() => exibirModal = false;
}
