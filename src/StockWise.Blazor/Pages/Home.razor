@page "/"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using StockWise.Domain.Entities
@using StockWise.Blazor.Services
@using StockWise.Domain.Extensions
@inject FrutaApiService ApiService
@inject IJSRuntime JSRuntime

<PageTitle>StockWise - Gestão de Frutas</PageTitle>


<div class="header-container">
    <div class="main-container">
        <div class="header-content">
            <h1 class="header-title">
                <span>🍉</span>
                StockWise
            </h1>
            <div class="header-actions">
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Buscar fruta..." @bind="termoBusca" @bind:event="oninput" />
                    </div>
                </div>
                <button class="btn-primary-custom" @onclick="AbrirModal">
                    <i class="bi bi-plus-circle"></i>
                    Nova Fruta
                </button>
            </div>
        </div>
    </div>
</div>

<div class="main-container">
    @if (frutas == null)
    {
        <div class="loading-container">
            <div class="spinner-custom"></div>
            <p class="loading-text">Conectando à API...</p>
        </div>
    }
    else if (!FrutasFiltradas.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📦</div>
            <p class="empty-state-text">
                @(string.IsNullOrWhiteSpace(termoBusca)
                    ? "Nenhuma fruta cadastrada no estoque."
                    : $"Nenhuma fruta encontrada para '{termoBusca}'.")
            </p>
        </div>
    }
    else
    {
        <div class="cards-grid">
            @foreach (var fruta in FrutasFiltradas)
            {
                <div class="fruit-card">
                    <div class="fruit-card-header">
                        <h5 class="fruit-card-title">
                            @(fruta.Nome?.ObterEmojiFruta() ?? "🍎")
                            @fruta.Nome
                        </h5>
                        <span class="fruit-card-id">ID: @fruta.Id</span>
                    </div>
                    <div class="fruit-card-body">
                        <div class="quantity-section">
                            <span class="quantity-badge @(fruta.Quantidade < 5 ? "low" : "")">
                                <i class="bi @(fruta.Quantidade < 5 ? "bi-exclamation-circle" : "bi-check-circle")"></i>
                                @fruta.Quantidade kg
                            </span>
                            <span class="quantity-label">Disponível</span>
                        </div>
                        <div class="price-section">
                            <span class="price-label">Preço</span>
                            <span class="price-value">R$ @fruta.Preco.ToString("F2")</span>
                        </div>
                    </div>
                    <div class="fruit-card-footer">
                        <button class="btn-action btn-edit" @onclick="() => AbrirModalEdicao(fruta)">
                            <i class="bi bi-pencil"></i>
                            Editar
                        </button>
                        <button class="btn-action btn-delete" @onclick="() => DeletarFruta(fruta.Nome!)">
                            <i class="bi bi-trash"></i>
                            Remover
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Modal de Cadastro/Edição *@
@if (exibirModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    @(novaFruta.Id == 0 ? "📦 Cadastrar Nova Fruta" : "✏️ Editar Fruta")
                </h5>
                <button type="button" class="modal-close-btn" @onclick="FecharModal">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <EditForm Model="@novaFruta" OnValidSubmit="SalvarFruta">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Nome da Fruta</label>
                        <InputText @bind-Value="novaFruta.Nome" class="form-input" placeholder="Ex: Morango"
                                   disabled="@(novaFruta.Id != 0)" required />
                        @if (novaFruta.Id != 0)
                        {
                            <div class="form-help-text">
                                <i class="bi bi-info-circle"></i>
                                O nome da fruta não pode ser alterado após o cadastro.
                            </div>
                        }
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Preço (R$)</label>
                            <InputNumber @bind-Value="novaFruta.Preco" class="form-input" step="0.01" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Quantidade (kg)</label>
                            <InputNumber @bind-Value="novaFruta.Quantidade" class="form-input" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-modal btn-cancel" @onclick="FecharModal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn-modal btn-submit">
                        @(novaFruta.Id == 0 ? "Salvar Fruta" : "Salvar Alterações")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Fruta>? frutas;
    private Fruta novaFruta = new();
    private string termoBusca = "";
    private bool exibirModal = false;

    private IEnumerable<Fruta> FrutasFiltradas =>
        frutas.FiltrarPorTexto(termoBusca, f => f.Nome);

    protected override async Task OnInitializedAsync() => await ListarAsync();

    // --- Métodos CRUD ---

    private async Task ListarAsync()
    {
        frutas = await CrudExtensions.CarregarDadosSafeAsync(
            () => ApiService.GetFrutasAsync(), "Frutas");
    }

    private async Task SalvarFruta()
    {
        bool sucesso;

        if (novaFruta.Id == 0)
        {
            sucesso = await CrudExtensions.SalvarSafeAsync(
                () => ApiService.CadastrarAsync(novaFruta),
                "Fruta"
            );
        }
        else
        {
            sucesso = await CrudExtensions.AtualizarSafeAsync(
                () => ApiService.AtualizarAsync(novaFruta),
                "Fruta"
            );
        }

        if (sucesso)
        {
            await ListarAsync();
            FecharModal();
        }
    }

    private async Task DeletarFruta(string nome)
    {
        var confirmou = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Deseja realmente remover a fruta '{nome}'?"
        );

        if (!confirmou)
            return;

        var sucesso = await CrudExtensions.DeletarSafeAsync(
            () => ApiService.RemoverAsync(nome),
            "Fruta"
        );

        if (sucesso)
            await ListarAsync();
    }

    private void AbrirModal()
    {
        novaFruta = new Fruta
        {
            Id = 0,
            Nome = "",
            Preco = 0,
            Quantidade = 0
        };
        exibirModal = true;
    }

    private void AbrirModalEdicao(Fruta fruta)
    {
        novaFruta = new Fruta
        {
            Id = fruta.Id,
            Nome = fruta.Nome,
            Preco = fruta.Preco,
            Quantidade = fruta.Quantidade
        };
        exibirModal = true;
    }

    private void FecharModal() => exibirModal = false;
}
