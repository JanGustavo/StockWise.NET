@page "/funcionarios"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using StockWise.Domain.Entities
@using StockWise.Blazor.Services
@using StockWise.Domain.Extensions
@inject FuncionarioApiService ApiService
@inject NotificationService Notification
@inject IJSRuntime JSRuntime

<PageTitle>StockWise - Funcionários</PageTitle>

<div class="header-container">
    <div class="main-container">
        <div class="header-content">
            <h1 class="header-title">
                <span>🛠️</span>
                Equipe
            </h1>
            <div class="header-actions">
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Buscar integrante..." @bind="termoBusca" @bind:event="oninput" />
                    </div>
                </div>
                <button class="btn-primary-custom" @onclick="AbrirModal">
                    <i class="bi bi-person-badge"></i>
                    Novo Integrante
                </button>
            </div>
        </div>
    </div>
</div>

<div class="main-container">
    @if (funcionarios == null)
    {
        <div class="loading-container">
            <div class="spinner-custom"></div>
            <p class="mt-3 text-secondary fw-bold">Carregando equipe...</p>
        </div>
    }
    else if (!FuncionariosFiltrados.Any())
    {
        <div class="empty-state">
            <div style="font-size: 4rem; margin-bottom: 1rem;">👥</div>
            <p class="text-secondary fw-bold">
                @(string.IsNullOrWhiteSpace(termoBusca) ? "Nenhum integrante cadastrado." : $"Nenhum funcionário encontrado para '{termoBusca}'.")
            </p>
        </div>
    }
    else
    {
        <div class="cards-grid">
            @foreach (var f in FuncionariosFiltrados)
            {
                <div class="staff-card">
                    <div class="staff-card-header">
                        <div class="staff-avatar">
                            @f.Nome.Substring(0, 1).ToUpper()
                        </div>
                        <div class="staff-info-header">
                            <h5 class="staff-name">@f.Nome</h5>
                            <span class="staff-role">@f.Cargo</span>
                        </div>
                    </div>
                    <div class="staff-card-body">
                        <div class="info-item">
                            <i class="bi bi-hash"></i>
                            <span>Identificador: #@f.Id</span>
                        </div>
                        <div class="info-item">
                            <i class="bi bi-envelope-at"></i>
                            <span>@f.Email</span>
                        </div>
                        <div class="salary-badge">
                            <span class="text-secondary small fw-bold">SALÁRIO MENSAL</span>
                            <span class="salary-value">R$ @f.Salario.ToString("F2")</span>
                        </div>
                    </div>
                    <div class="staff-card-footer">
                        <button class="btn-action btn-edit" @onclick="() => AbrirModalEdicao(f)">
                            <i class="bi bi-pencil"></i> Editar
                        </button>
                        <button class="btn-action btn-delete" @onclick="() => DeletarAsync(f.Id, f.Nome)">
                            <i class="bi bi-trash"></i> Remover
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Modal de Cadastro *@
@if (exibirModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi @(novoFuncionario.Id == 0 ? "bi-person-plus-fill" : "bi-pencil-square")"></i>
                    @(novoFuncionario.Id == 0 ? "Novo Integrante" : "Editar Integrante")
                </h5>
                <button type="button" class="modal-close-btn" @onclick="FecharModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <EditForm Model="@novoFuncionario" OnValidSubmit="SalvarAsync">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Nome Completo</label>
                        <InputText @bind-Value="novoFuncionario.Nome" class="form-input" placeholder="Ex: Maria Oliveira" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Cargo</label>
                        <InputText @bind-Value="novoFuncionario.Cargo" class="form-input" placeholder="Ex: Gerente de Vendas" required />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Salário (R$)</label>
                            <InputNumber @bind-Value="novoFuncionario.Salario" class="form-input" step="0.01" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email Corporativo</label>
                            <InputText @bind-Value="novoFuncionario.Email" type="email" class="form-input" placeholder="maria@stockwise.com" required />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Senha de Acesso</label>
                        <InputText @bind-Value="novoFuncionario.Senha" type="password" class="form-input" placeholder="••••••••" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-modal btn-cancel" @onclick="FecharModal">Cancelar</button>
                    <button type="submit" class="btn-modal btn-submit">
                        @(novoFuncionario.Id == 0 ? "Cadastrar Integrante" : "Salvar Alterações")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Funcionario>? funcionarios;
    private Funcionario novoFuncionario = new();
    private string termoBusca = "";
    private bool exibirModal = false;

    private IEnumerable<Funcionario> FuncionariosFiltrados =>
        funcionarios.FiltrarPorTexto(termoBusca, f => f.Nome);

    protected override async Task OnInitializedAsync() => await ListarAsync();

    private async Task ListarAsync()
    {
        try
        {
            funcionarios = await ApiService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro ao carregar equipe: {ex.Message}");
            funcionarios = new();
        }
    }

    private async Task SalvarAsync()
    {
        HttpResponseMessage response;
        string acao = novoFuncionario.Id == 0 ? "cadastrar" : "atualizar";

        try
        {
            if (novoFuncionario.Id == 0)
                response = await ApiService.CreateAsync(novoFuncionario);
            else
                response = await ApiService.UpdateAsync(novoFuncionario);

            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess($"Funcionário {acao}do com sucesso!");
                FecharModal();
                await ListarAsync();
            }
            else
            {
                var erro = await ApiServiceHelper.GetErrorMessageAsync(response);
                Notification.ShowError($"Erro ao {acao}: {erro}");
            }
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro crítico ao {acao}: {ex.Message}");
        }
    }

    private async Task DeletarAsync(int id, string nome)
    {
        var confirmou = await JSRuntime.InvokeAsync<bool>("confirm", $"Deseja realmente remover o funcionário '{nome}'?");
        if (!confirmou) return;

        try
        {
            var response = await ApiService.DeleteAsync(id);
            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess("Funcionário removido com sucesso!");
                await ListarAsync();
            }
            else
            {
                var erro = await ApiServiceHelper.GetErrorMessageAsync(response);
                Notification.ShowError($"Erro ao remover: {erro}");
            }
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro crítico ao remover: {ex.Message}");
        }
    }

    private void AbrirModal()
    {
        novoFuncionario = new Funcionario { Nome = "", Email = "", Cargo = "", Salario = 0, Senha = "" };
        exibirModal = true;
    }

    private void AbrirModalEdicao(Funcionario funcionario)
    {
        novoFuncionario = new Funcionario
        {
            Id = funcionario.Id,
            Nome = funcionario.Nome,
            Email = funcionario.Email,
            Cargo = funcionario.Cargo,
            Salario = funcionario.Salario,
            Senha = funcionario.Senha
        };
        exibirModal = true;
    }

    private void FecharModal() => exibirModal = false;
}
