@page "/pedidos"
@using StockWise.Domain.Entities
@using StockWise.Blazor.Services
@using StockWise.Domain.Extensions
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms

@inject PedidoApiService ApiService
@inject ClienteApiService ClienteService
@inject NotificationService Notification
@inject IJSRuntime JSRuntime

<PageTitle>StockWise - Pedidos</PageTitle>

<div class="header-container">
    <div class="main-container">
        <div class="header-content">
            <h1 class="header-title">
                <span>📝</span>
                Pedidos
            </h1>
            <div class="header-actions">
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Filtrar pedidos..." @bind="termoBusca" @bind:event="oninput" />
                    </div>
                </div>
                <button class="btn-primary-custom" @onclick="AbrirModal">
                    <i class="bi bi-plus-circle"></i>
                    Novo Pedido
                </button>
            </div>
        </div>
    </div>
</div>

<div class="main-container">
    @if (pedidos == null)
    {
        <div class="loading-container">
            <div class="spinner-custom"></div>
            <p class="mt-4 text-secondary fw-bold">Carregando histórico...</p>
        </div>
    }
    else if (!PedidosFiltrados.Any())
    {
        <div class="empty-state" style="text-align: center; padding: 5rem;">
            <div style="font-size: 4rem; margin-bottom: 1rem;">📄</div>
            <p class="text-secondary fw-bold">
                @(string.IsNullOrWhiteSpace(termoBusca) ? "Nenhum pedido registrado." : $"Nenhum pedido encontrado para '{termoBusca}'.")
            </p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Data</th>
                        <th>Cliente</th>
                        <th>Tipo</th>
                        <th>Descrição</th>
                        <th>Valor Total</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in PedidosFiltrados)
                    {
                        <tr>
                            <td class="order-id">#@p.Id</td>
                            <td class="order-date">@p.Data.ToShortDateString()</td>
                            <td>
                                <div class="d-flex align-items-center gap-2" title="ID do Cliente: @p.ClienteId">
                                    <div
                                        style="width: 32px; height: 32px; background: #f1f5f9; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem;">
                                        👤
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold" style="font-size: 0.9rem;">@(p.Cliente?.Nome ?? "Cliente Externo")</span>
                                        <span class="text-muted" style="font-size: 0.75rem;">ID: #@p.ClienteId</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="type-badge @(p.Tipo == "Venda" ? "type-venda" : "type-compra")">
                                    <i
                                    class="bi @(p.Tipo == "Venda" ? "bi-arrow-up-circle-fill" : "bi-arrow-down-circle-fill")"></i>
                                    @(p.Tipo == "Venda" ? "Venda" : "Despesa")
                                </span>
                            </td>
                            
                            <td>
                                @(string.IsNullOrWhiteSpace(p.Descricao) ? "-" : p.Descricao)
                            </td>

                            <td class="@(p.Tipo == "Venda" ? "value-venda" : "value-compra")">
                                @(p.Tipo == "Compra" ? "-" : "+") R$ @p.ValorTotal.ToString("F2")
                            </td>
                            <td class="text-end">
                                <button class="btn-action-sm btn-edit-sm me-2" @onclick="() => AbrirModalEdicao(p)"
                                        title="Editar">
                                    <i class="bi bi-pencil-fill"></i>
                                </button>
                                <button class="btn-action-sm btn-delete-sm" @onclick="() => DeletarAsync(p.Id, p.Tipo)"
                                        title="Excluir">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Modal de Cadastro/Edição *@
@if (exibirModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi @(novoPedido.Id == 0 ? "bi-plus-square-fill" : "bi-pencil-square")"></i>
                    @(novoPedido.Id == 0 ? "Novo Pedido" : "Editar Pedido")
                </h5>
                <button type="button" class="modal-close-btn" @onclick="FecharModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <EditForm Model="@novoPedido" OnValidSubmit="SalvarAsync">
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Tipo de Transação</label>
                        <InputSelect @bind-Value="novoPedido.Tipo" class="form-select" required>
                            <option value="">Selecione o tipo...</option>
                            <option value="Venda">Venda (Entrada de Capital)</option>
                            <option value="Compra">Despesa (Saída de Capital)</option>
                        </InputSelect>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Descrição / Observações</label>
                        <InputText @bind-Value="novoPedido.Descricao" class="form-input"
                                   placeholder="Ex: Venda de 10kg de Morango" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Valor Total (R$)</label>
                        <div class="position-relative">
                            <span
                            style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); font-weight: 700; color: var(--text-secondary);">R$</span>
                            <InputNumber @bind-Value="novoPedido.ValorTotal" class="form-input" style="padding-left: 3rem;"
                                         step="0.01" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Vincular Cliente</label>
                        <div class="client-selector">
                            <div class="position-relative flex-grow-1">
                                <i class="bi bi-person"
                                   style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-secondary);"></i>
                                <InputNumber @bind-Value="novoPedido.ClienteId" class="form-input"
                                             style="padding-left: 2.5rem;" placeholder="ID do Cliente" required readonly />
                            </div>
                            <button class="btn-modal" type="button" style="background: #f1f5f9; padding: 0 1.25rem;"
                                    @onclick="AbrirSelecaoCliente">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                        
                        @if (clienteSelecionado != null)
                        {
                            <div class="client-preview">
                                <i class="bi bi-check-circle-fill"></i>
                                Cliente: @clienteSelecionado.Nome
                            </div>
                        }
                        else if (novoPedido.ClienteId > 0)
                        {
                            <div class="form-text text-danger mt-2">
                                <i class="bi bi-exclamation-triangle"></i> Cliente não identificado.
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-modal btn-cancel" @onclick="FecharModal">Cancelar</button>
                    <button type="submit" class="btn-modal btn-submit" disabled="@(clienteSelecionado == null)">
                        @(novoPedido.Id == 0 ? "Finalizar Pedido" : "Atualizar Pedido")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* Picker de Cliente *@
@if (exibirSelecaoCliente)
{
    <div class="picker-modal">
        <div class="picker-content">
            <div class="picker-header">
                <h6 class="m-0 fw-bold">Selecionar Cliente</h6>
                <button type="button" class="btn-close" @onclick="FecharSelecaoCliente"></button>
            </div>
            <div class="p-3 border-bottom">
                <div class="position-relative">
                    <i class="bi bi-filter"
                       style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--text-secondary);"></i>
                    <input type="text" class="form-control form-control-sm" style="padding-left: 2rem; border-radius: 8px;"
                           placeholder="Filtrar clientes..." @bind="termoBuscaCliente" @bind:event="oninput" />
                </div>
            </div>
            <div class="picker-body">
                @foreach (var c in ClientesFiltradosParaSelecao)
                {
                    <button type="button" class="picker-item" @onclick="() => SelecionarCliente(c)">
                        <strong>#@c.Id</strong>
                        <span>@c.Nome</span>
                    </button>
                }
                @if (!ClientesFiltradosParaSelecao.Any())
                {
                    <div class="text-center py-4 text-muted small">Nenhum cliente encontrado.</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Pedido>? pedidos;
    private List<Cliente>? todosClientes;
    private Cliente? clienteSelecionado;

    private Pedido novoPedido = new Pedido { Tipo = "" };

    private string termoBusca = "";
    private string termoBuscaCliente = "";

    private bool exibirModal = false;
    private bool exibirSelecaoCliente = false;

    private IEnumerable<Pedido> PedidosFiltrados =>
        pedidos?.Where(p =>
            string.IsNullOrWhiteSpace(termoBusca) ||
            p.Tipo.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) ||
            p.Id.ToString().Contains(termoBusca) ||
            p.ClienteId.ToString().Contains(termoBusca) ||
            (p.Cliente?.Nome?.Contains(termoBusca, StringComparison.OrdinalIgnoreCase) ?? false)
        ) ?? Enumerable.Empty<Pedido>();

    private IEnumerable<Cliente> ClientesFiltradosParaSelecao =>
        todosClientes.FiltrarPorTexto(termoBuscaCliente, c => c.Nome);

    protected override async Task OnInitializedAsync()
    {
        await ListarAsync();
        await CarregarClientesAsync();
    }

    private async Task CarregarClientesAsync()
    {
        try
        {
            todosClientes = await ClienteService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro ao carregar clientes: {ex.Message}");
            todosClientes = new();
        }
    }

    private async Task ListarAsync()
    {
        try
        {
            pedidos = await ApiService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro ao carregar pedidos: {ex.Message}");
            pedidos = new();
        }
    }

    private async Task SalvarAsync()
    {
        if (novoPedido.ValorTotal <= 0)
        {
            Notification.ShowWarning("O valor do pedido deve ser maior que zero!");
            return;
        }

        HttpResponseMessage response;
        string acao = novoPedido.Id == 0 ? "finalizar" : "atualizar";

        try
        {
            if (novoPedido.Id == 0)
                response = await ApiService.CreateAsync(novoPedido);
            else
                response = await ApiService.UpdateAsync(novoPedido);

            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess($"Pedido {acao}do com sucesso!");
                FecharModal();
                await ListarAsync();
            }
            else
            {
                var erro = await ApiServiceHelper.GetErrorMessageAsync(response);
                Notification.ShowError($"Erro ao {acao} pedido: {erro}");
            }
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro crítico ao {acao} pedido: {ex.Message}");
        }
    }

    private async Task DeletarAsync(int id, string nome)
    {
        var confirmou = await JSRuntime.InvokeAsync<bool>("confirm", $"Deseja realmente remover o pedido '#{id}'?");
        if (!confirmou) return;

        try
        {
            var response = await ApiService.DeleteAsync(id);
            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess("Pedido removido com sucesso!");
                await ListarAsync();
            }
            else
            {
                var erro = await ApiServiceHelper.GetErrorMessageAsync(response);
                Notification.ShowError($"Erro ao remover pedido: {erro}");
            }
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro crítico ao remover pedido: {ex.Message}");
        }
    }
    
    private void AbrirSelecaoCliente()
    {
        termoBuscaCliente = "";
        exibirSelecaoCliente = true;
    }

    private void FecharSelecaoCliente() => exibirSelecaoCliente = false;

    private void SelecionarCliente(Cliente cliente)
    {
        novoPedido.ClienteId = cliente.Id;
        clienteSelecionado = cliente;
        FecharSelecaoCliente();
    }

    private void AbrirModal()
    {
        novoPedido = new Pedido
        {
            Id = 0,
            Data = DateTime.Now,
            Tipo = "Venda",
            Descricao = "",
            ValorTotal = 0,
            ClienteId = 0
        };
        clienteSelecionado = null;
        exibirModal = true;
    }

    private void AbrirModalEdicao(Pedido pedido)
    {
        novoPedido = new Pedido
        {
            Id = pedido.Id,
            Data = pedido.Data,
            Tipo = pedido.Tipo,
            Descricao = pedido.Descricao,
            ValorTotal = pedido.ValorTotal,
            ClienteId = pedido.ClienteId
        };
        clienteSelecionado = todosClientes?.FirstOrDefault(c => c.Id == pedido.ClienteId);
        exibirModal = true;
    }

    private void FecharModal() => exibirModal = false;
}
